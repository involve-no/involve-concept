---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt oss - Involve! Advertising" description="Ta kontakt med oss i Involve! Advertising. Vi holder til i Grensen 3 i Oslo.">
  
  <!-- Page Header -->
  <section class="bg-[#F9F9F9] border-b border-[#E7E7E7]/40 py-20 px-6 mt-20">
    <div class="max-w-[1600px] mx-auto">
      <span class="text-xs font-bold text-[#565B5C] uppercase tracking-[3px] block mb-3">La oss snakke sammen</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#162022] tracking-tight leading-tight">
        Kontakt oss
      </h1>
      <p class="text-[#3F4344] font-light leading-relaxed max-w-[600px] mt-4 text-[17px] md:text-[19px]">
        Vi gleder oss til å høre fra deg, enten du har et konkret prosjekt eller bare vil slå av en hyggelig kaffeprat.
      </p>
    </div>
  </section>

  <!-- Contact Form & Details Section -->
  <section class="py-20 bg-white px-6">
    <div class="max-w-[1600px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        
        <!-- Contact Information (left 5 columns) -->
        <div class="lg:col-span-5 space-y-12">
          <div>
            <h2 class="text-2xl font-bold text-[#162022] mb-6">Involve Oslo</h2>
            <div class="space-y-4 text-[16px] text-[#3F4344] leading-relaxed">
              <div class="flex items-start gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-6 h-6 text-[#565B5C] mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <div>
                  <p class="font-semibold text-[#162022]">Besøksadresse:</p>
                  <p>Grensen 3, 0159 Oslo</p>
                  <p class="text-sm text-[#565B5C] mt-1">(4. etasje, inngang fra Grensen)</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-6 h-6 text-[#565B5C] mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                <div>
                  <p class="font-semibold text-[#162022]">Telefon:</p>
                  <a href="tel:+4724124500" class="hover:underline">+47 24 12 45 00</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-6 h-6 text-[#565B5C] mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <div>
                  <p class="font-semibold text-[#162022]">E-post:</p>
                  <a href="mailto:post@involve.no" class="hover:underline">post@involve.no</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Maps Placeholder -->
          <div class="w-full aspect-[16/10] bg-[#F9F9F9] rounded-[12px] border border-[#E7E7E7]/50 overflow-hidden relative shadow-sm">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2000.1245781249768!2d10.742358877544033!3d59.9135048749005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x46416e624c4dc8c9%3A0xe54e60655e0947e4!2sGrensen%203%2C%200159%20Oslo!5e0!3m2!1sno!2sno!4v1700000000000!5m2!1sno!2sno" 
              class="w-full h-full border-0 grayscale opacity-80" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <!-- Contact Form (right 7 columns) -->
        <div class="lg:col-span-7 bg-[#F9F9F9] p-8 md:p-12 rounded-[16px] border border-[#E7E7E7]/40 shadow-sm">
          <h3 class="text-2xl font-bold text-[#162022] mb-2">Send oss en melding</h3>
          <p class="text-sm text-[#565B5C] mb-8 font-light">Fyll ut skjemaet under, så tar vi kontakt så fort som mulig.</p>
          
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs font-semibold text-[#565B5C] uppercase tracking-wider mb-2">Navn *</label>
                <input 
                  type="text" 
                  id="name" 
                  required 
                  class="w-full px-4 py-3 rounded-[6px] border border-[#E7E7E7] bg-white text-[#162022] focus:outline-none focus:border-[#162022] transition-colors"
                />
              </div>
              <div>
                <label for="company" class="block text-xs font-semibold text-[#565B5C] uppercase tracking-wider mb-2">Bedrift</label>
                <input 
                  type="text" 
                  id="company" 
                  class="w-full px-4 py-3 rounded-[6px] border border-[#E7E7E7] bg-white text-[#162022] focus:outline-none focus:border-[#162022] transition-colors"
                />
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-xs font-semibold text-[#565B5C] uppercase tracking-wider mb-2">E-post *</label>
                <input 
                  type="email" 
                  id="email" 
                  required 
                  class="w-full px-4 py-3 rounded-[6px] border border-[#E7E7E7] bg-white text-[#162022] focus:outline-none focus:border-[#162022] transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs font-semibold text-[#565B5C] uppercase tracking-wider mb-2">Telefonnummer</label>
                <input 
                  type="tel" 
                  id="phone" 
                  class="w-full px-4 py-3 rounded-[6px] border border-[#E7E7E7] bg-white text-[#162022] focus:outline-none focus:border-[#162022] transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-[#565B5C] uppercase tracking-wider mb-2">Melding *</label>
              <textarea 
                id="message" 
                rows="6" 
                required 
                class="w-full px-4 py-3 rounded-[6px] border border-[#E7E7E7] bg-white text-[#162022] focus:outline-none focus:border-[#162022] transition-colors resize-y"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input 
                type="checkbox" 
                id="privacy-check" 
                required 
                class="mt-1 cursor-pointer accent-[#F5FF8C]"
              />
              <label for="privacy-check" class="text-xs text-[#565B5C] leading-snug">
                Jeg samtykker til at Involve kan lagre og behandle mine personopplysninger i henhold til 
                <a href="/personvernerklaering" class="underline hover:no-underline text-[#162022]">personvernerklæringen</a>. *
              </label>
            </div>

            <button 
              type="submit" 
              class="w-full py-4 rounded-[6px] bg-[#F5FF8C] text-[#162022] font-semibold text-[15px] border border-[#F5FF8C] transition-all duration-300 hover:bg-white hover:border-[#162022] hover:scale-101 hover:shadow-sm"
            >
              Send melding
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
