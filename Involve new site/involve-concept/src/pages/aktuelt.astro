---
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = [
  {
    title: 'Involve lanserer nye nettsider for 2026',
    date: '22. juni 2026',
    category: 'Aktuelt',
    excerpt: 'Vi er stolte av å presentere vår splitter nye digitale plattform, bygget med moderne rammeverk for optimal ytelse og brukeropplevelse.',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800&h=450'
  },
  {
    title: 'Gull til Involve i prestisjefylt reklamekåring',
    date: '10. mai 2026',
    category: 'Priser',
    excerpt: 'Vår kampanje for Schweppes høster internasjonal anerkjennelse og stakk av med gulleffekten under årets utdeling.',
    image: 'https://images.unsplash.com/photo-1578575437130-527eed3abbec?auto=format&fit=crop&q=80&w=800&h=450'
  },
  {
    title: 'Slik lykkes du med digital synlighet i år',
    date: '04. april 2026',
    category: 'Innsikt',
    excerpt: 'Hvilke trender preger det digitale landskapet, og hvordan bør din bedrift prioritere ressursene for maksimal effekt? Les våre råd her.',
    image: 'https://images.unsplash.com/photo-1432821596592-e2c18b78144f?auto=format&fit=crop&q=80&w=800&h=450'
  }
];
---

<BaseLayout title="Aktuelt - Involve! Advertising" description="Siste nytt, presseomtaler og faglig innsikt fra oss i Involve! i Oslo.">
  
  <!-- Page Header -->
  <section class="bg-[#F9F9F9] border-b border-[#E7E7E7]/40 py-20 px-6 mt-20">
    <div class="max-w-[1600px] mx-auto">
      <span class="text-xs font-bold text-[#565B5C] uppercase tracking-[3px] block mb-3">Siste nytt</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#162022] tracking-tight leading-tight">
        Aktuelt & Innsikt
      </h1>
      <p class="text-[#3F4344] font-light leading-relaxed max-w-[600px] mt-4 text-[17px] md:text-[19px]">
        Her deler vi nyheter om våre prosjekter, faglige betraktninger, trender og hendelser i byrået.
      </p>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-20 bg-white px-6">
    <div class="max-w-[1600px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {articles.map((post) => (
          <article class="group flex flex-col h-full bg-[#F9F9F9] rounded-[12px] border border-[#E7E7E7]/30 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="aspect-[16/9] w-full overflow-hidden bg-[#E7E7E7]">
              <img 
                src={post.image} 
                alt={post.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-103"
              />
            </div>
            <div class="p-6 md:p-8 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-4 text-xs font-semibold text-[#565B5C]">
                <span class="bg-white px-3 py-1 rounded-full border border-[#E7E7E7]">{post.category}</span>
                <span>{post.date}</span>
              </div>
              <h2 class="text-xl md:text-2xl font-bold text-[#162022] leading-tight mb-4 group-hover:text-[#3F4344] transition-colors">
                {post.title}
              </h2>
              <p class="text-[15px] font-light text-[#3F4344] leading-relaxed mb-6 flex-grow">
                {post.excerpt}
              </p>
              <span class="inline-flex items-center text-sm font-bold text-[#162022] gap-1 group-hover:underline">
                Les mer
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
