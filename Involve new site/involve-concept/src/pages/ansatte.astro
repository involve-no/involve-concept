---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamMemberCard from '../components/TeamMemberCard.astro';

const team = [
  {
    name: 'Linn Tidemandsen',
    role: 'Byråleder / Partner',
    division: 'Involve Advertising',
    phone: '900 12 345',
    email: 'linn@involve.no',
    image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=600&h=600'
  },
  {
    name: 'Celine Sagenes',
    role: 'Kreativ Leder',
    division: 'Involve Advertising',
    phone: '930 60 290',
    email: 'celine@involve.no',
    image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=600&h=600'
  },
  {
    name: 'Desiree Olsen',
    role: 'Senior Prosjektleder / Rådgiver',
    division: 'Involve Advertising',
    phone: '918 71 366',
    email: 'desiree@involve.no',
    image: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=600&h=600'
  },
  {
    name: 'Sondre Arthur Bye',
    role: 'Grafisk Designer',
    division: 'Involve Advertising',
    phone: '924 88 112',
    email: 'sondre@involve.no',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=600&h=600'
  }
];
---

<BaseLayout title="Ansatte - Involve! Advertising" description="Oversikt over alle flinke folk som jobber hos Involve! i Oslo.">
  
  <!-- Page Header -->
  <section class="bg-[#F9F9F9] border-b border-[#E7E7E7]/40 py-20 px-6 mt-20">
    <div class="max-w-[1600px] mx-auto">
      <span class="text-xs font-bold text-[#565B5C] uppercase tracking-[3px] block mb-3">Våre folk</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#162022] tracking-tight leading-tight">
        Møt folka i Involve
      </h1>
      <p class="text-[#3F4344] font-light leading-relaxed max-w-[600px] mt-4 text-[17px] md:text-[19px]">
        Vi er strategiske rådgivere, kreatører, designere, innholdsprodusenter og prosjektledere. Bli bedre kjent med oss her.
      </p>
    </div>
  </section>

  <!-- Team Directory Section -->
  <section class="py-20 bg-white px-6">
    <div class="max-w-[1600px] mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        {team.map((member) => (
          <TeamMemberCard 
            name={member.name}
            role={member.role}
            division={member.division}
            phone={member.phone}
            email={member.email}
            image={member.image}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
