---
interface Props {
  title: string;
  description: string;
  category: string;
  image: string;
  href?: string;
}

const { 
  title, 
  description, 
  category, 
  image, 
  href = "#" 
} = Astro.props;
---

<div class="group relative flex flex-col bg-white rounded-[15px] overflow-hidden border border-[#E7E7E7]/40 shadow-sm transition-all duration-500 hover:shadow-xl hover:translate-y-[-4px] h-full">
  
  <!-- Image Container -->
  <div class="relative w-full aspect-[4/3] overflow-hidden bg-gray-100">
    <a href={href} aria-label={`Se case: ${title}`}>
      <img 
        src={image} 
        alt={title} 
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      />
    </a>
    <!-- Category Overlay Badge -->
    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-[4px] border border-white/20">
      <span class="text-[10px] font-bold text-[#162022] tracking-wider uppercase">
        {category}
      </span>
    </div>
  </div>

  <!-- Content Block -->
  <div class="flex-grow p-6 flex flex-col justify-between">
    <div>
      <h3 class="text-xl font-bold text-[#162022] mb-3 leading-snug group-hover:text-[#565B5C] transition-colors">
        <a href={href}>
          {title}
        </a>
      </h3>
      <p class="text-sm font-light text-[#3F4344] leading-relaxed mb-6 line-clamp-3">
        {description}
      </p>
    </div>

    <!-- Signature Involve Split Button -->
    <div class="flex items-center mt-auto">
      <a 
        href={href} 
        class="inline-flex h-[36px] items-stretch rounded-[4px] overflow-hidden border border-[#E7E7E7] hover:border-[#162022] transition-colors duration-300"
      >
        <!-- Left Part: "SE CASE" -->
        <span class="flex items-center px-4 bg-white text-[11px] font-bold tracking-wider text-[#162022] uppercase group-hover:bg-[#F9F9F9] transition-colors duration-300">
          Se Case
        </span>
        <!-- Right Part: Neon Accent with Arrow -->
        <span class="flex items-center justify-center w-[36px] bg-[#F5FF8C] text-[#162022] group-hover:bg-[#F6FF45] transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L9.78 4.612a.75.75 0 1 1 1.06-1.06l6.25 6.25a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 1 1-1.06-1.06l4.608-4.612H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </span>
      </a>
    </div>

  </div>

</div>
