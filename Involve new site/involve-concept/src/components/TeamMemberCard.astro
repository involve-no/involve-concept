---
interface Props {
  name: string;
  role: string;
  division: string;
  phone?: string;
  email?: string;
  image: string;
}

const { 
  name, 
  role, 
  division, 
  phone, 
  email, 
  image 
} = Astro.props;
---

<div class="group flex flex-col bg-[#F9F9F9] rounded-xl overflow-hidden border border-[#E7E7E7]/30 transition-all duration-300 hover:shadow-lg hover:border-[#162022]/10">
  
  <!-- Image Frame -->
  <div class="w-full aspect-square overflow-hidden bg-gray-100 relative">
    <img 
      src={image} 
      alt={name} 
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-102"
    />
  </div>

  <!-- Profile details -->
  <div class="p-6 md:p-8 flex flex-col justify-between flex-grow">
    
    <div>
      <!-- Name -->
      <h3 class="text-xl font-bold text-[#162022] mb-1">
        {name}
      </h3>
      
      <!-- Role / Division -->
      <div class="flex flex-col text-[14px] text-[#565B5C] mb-6">
        <span class="font-medium text-[#162022]/80">{role}</span>
        <span class="text-xs">{division}</span>
      </div>
    </div>

    <!-- Contact details -->
    {(phone || email) && (
      <div class="border-t border-[#E7E7E7]/60 pt-4 flex flex-col gap-2 text-xs text-[#565B5C]">
        {phone && (
          <a href={`tel:${phone.replace(/\s+/g, '')}`} class="hover:text-[#162022] transition-colors">
            Tlf: {phone}
          </a>
        )}
        {email && (
          <a href={`mailto:${email}`} class="hover:text-[#162022] transition-colors break-all flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 flex-shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            {email}
          </a>
        )}
      </div>
    )}

  </div>

</div>
